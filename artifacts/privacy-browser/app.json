{
  "expo": {
    "name": "Null Trace",
    "slug": "null-trace",
    "owner": "student48",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nulltrace",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B2FBF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kakarot.nulltrace",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow camera access for sites that request it",
        "NSMicrophoneUsageDescription": "Allow microphone access for sites that request it",
        "NSLocationWhenInUseUsageDescription": "Allow location access for sites that request it",
        "NSFaceIDUsageDescription": "Use Face ID to unlock Privacy Browser"
      }
    },
    "android": {
      "package": "com.kakarot.nulltrace",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "DOWNLOAD_WITHOUT_NOTIFICATION",
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to unlock Privacy Browser"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "8c973d7a-2db1-4315-b24f-19e48b33d44c"
      }
    }
  }
}
